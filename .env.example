# ── Groq AI (FREE) ───────────────────────────────────────────────────────────
# Get your free key in 2 minutes at https://console.groq.com
# No credit card needed. 6000 tokens/min free.
GROQ_API_KEY=gsk_YOUR_API_KEY_HERE

# ── Database ─────────────────────────────────────────────────────────────────
# Leave blank for SQLite (works locally + Railway/Render with disk)
# Paste Postgres URL from Railway/Render if you want Postgres:
# DATABASE_URL=postgresql://user:password@host:5432/dbname
DATABASE_URL=

# ── Server ───────────────────────────────────────────────────────────────────
PORT=8000
HOST=0.0.0.0
